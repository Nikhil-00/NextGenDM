# ─── App ──────────────────────────────────────────────
DEBUG=true

# ─── Supabase PostgreSQL ──────────────────────────────
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# ─── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Redis (local: docker run -d -p 6379:6379 redis) ──
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_random_secret_32_chars_minimum

# ─── Meta App ─────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_verify_token

# ─── Instagram OAuth ──────────────────────────────────
# For local testing use ngrok: https://abc123.ngrok.io/api/v1/instagram/callback
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/instagram/callback

# ─── Frontend URL ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]
